# Database Configuration
# The connection string for your MongoDB instance.
# Example: mongodb://localhost:27017
MONGO_URI=

# OpenAI API Key
# The secret key used to authenticate with the OpenAI API for generating study plans.
# Example: sk-...
OPENAI_API_KEY=

# API Configuration
# Port on which the FastAPI application will run.
# Example: 8000
PORT=8000

# Environment mode (e.g., development, production)
# Example: development
ENVIRONMENT=development
